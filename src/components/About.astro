---
import { copy, photos, type Lang } from '../data/site';
interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const c = copy[lang];
const a = c.about;
---

<section class="about reveal" id="about">
  <div class="wrap about-grid">
    <div class="about-media">
      {photos.gallery.map((g, i) => (
        <figure class={`photo gphoto gphoto-${i}`}>
          <img src={g.src} alt={g[lang]} loading="lazy" onerror="this.style.display='none'" />
          <figcaption class="photo-label">{c.photoPlaceholder}</figcaption>
        </figure>
      ))}
    </div>

    <div class="about-body">
      <p class="eyebrow">{a.title}</p>
      <h2 class="about-title">{c.tagline}</h2>
      {a.body.map((para) => <p class="about-p">{para}</p>)}

      <dl class="facts">
        {a.facts.map((f) => (
          <div class="fact">
            <dt>{f.k}</dt>
            <dd>{f.v}</dd>
          </div>
        ))}
      </dl>
    </div>
  </div>
</section>

<style>
  .about-grid {
    display: grid;
    grid-template-columns: 0.85fr 1.15fr;
    gap: clamp(28px, 5vw, 64px);
    align-items: center;
  }
  .about-media {
    display: grid;
    grid-template-columns: 1fr 1fr;
    grid-auto-rows: 130px;
    gap: 14px;
  }
  .gphoto {
    font-size: 0.7rem;
  }
  .gphoto-0 {
    grid-column: 1 / 3;
    grid-row: span 2;
  }
  .gphoto-1,
  .gphoto-2 {
    grid-row: span 1;
  }
  .about-title {
    font-size: clamp(1.7rem, 4vw, 2.6rem);
    margin-bottom: 1.2rem;
    max-width: 18ch;
  }
  .about-p {
    color: var(--text-2);
    margin: 0 0 1.1rem;
    max-width: 58ch;
  }
  .facts {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin: 1.8rem 0 0;
  }
  .fact {
    border: 1px solid var(--hairline);
    border-radius: 14px;
    padding: 12px 16px;
    background: rgba(255, 228, 199, 0.02);
  }
  .fact dt {
    font-family: var(--font-mono);
    font-size: 0.64rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--amber);
    margin-bottom: 4px;
  }
  .fact dd {
    margin: 0;
    color: var(--text);
    font-size: 0.95rem;
  }
  @media (max-width: 780px) {
    .about-grid {
      grid-template-columns: 1fr;
    }
    .about-media {
      order: -1;
    }
  }
</style>
