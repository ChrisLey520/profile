---
// 统一线性图标集 —— 1.6 描边 / 24 网格 / currentColor,全站风格一致
interface Props {
  name:
    | 'glow'
    | 'ai'
    | 'server'
    | 'ship'
    | 'wechat'
    | 'arrow'
    | 'copy'
    | 'check'
    | 'pin'
    | 'sparkle';
  size?: number;
  class?: string;
}
const { name, size = 24, class: cls } = Astro.props;

const paths: Record<string, string> = {
  // 补光:太阳/光束
  glow: '<circle cx="12" cy="12" r="4"/><path d="M12 3v2M12 19v2M3 12h2M19 12h2M5.6 5.6l1.4 1.4M17 17l1.4 1.4M18.4 5.6L17 7M7 17l-1.4 1.4"/>',
  // AI:中枢节点
  ai: '<circle cx="12" cy="12" r="3"/><path d="M12 4v2M12 18v2M4 12h2M18 12h2"/><circle cx="12" cy="4" r="1.4"/><circle cx="12" cy="20" r="1.4"/><circle cx="4" cy="12" r="1.4"/><circle cx="20" cy="12" r="1.4"/>',
  // 服务器 / 自托管
  server:
    '<rect x="3" y="4" width="18" height="7" rx="2"/><rect x="3" y="13" width="18" height="7" rx="2"/><path d="M7 7.5h.01M7 16.5h.01"/>',
  // 启动 / 火箭
  ship: '<path d="M12 3c3 1.5 5 4.5 5 8l-1.5 4.5h-7L7 11c0-3.5 2-6.5 5-8Z"/><circle cx="12" cy="9" r="1.6"/><path d="M9 17c-1.5.8-2 2.5-2 4 1.5 0 3.2-.5 4-2M15 17c1.5.8 2 2.5 2 4-1.5 0-3.2-.5-4-2"/>',
  // 微信
  wechat:
    '<path d="M9 4C5.1 4 2 6.6 2 9.9c0 1.8 1 3.4 2.6 4.5L4 17l2.9-1.5c.7.2 1.4.3 2.1.3M17 8c-3.3 0-6 2.3-6 5.2S13.7 18 17 18c.6 0 1.2-.1 1.8-.3L21 19l-.5-1.9c1-.9 1.5-2 1.5-3.9C22 10.3 20.3 8 17 8Z"/><path d="M7 9h.01M11 9h.01M15.5 12.5h.01M18.5 12.5h.01"/>',
  arrow: '<path d="M5 12h14M13 6l6 6-6 6"/>',
  copy: '<rect x="9" y="9" width="11" height="11" rx="2"/><path d="M5 15V5a2 2 0 0 1 2-2h10"/>',
  check: '<path d="M4 12.5 9 17.5 20 6.5"/>',
  pin: '<path d="M12 21s7-5.7 7-11a7 7 0 1 0-14 0c0 5.3 7 11 7 11Z"/><circle cx="12" cy="10" r="2.5"/>',
  sparkle:
    '<path d="M12 3l1.8 5.2L19 10l-5.2 1.8L12 17l-1.8-5.2L5 10l5.2-1.8L12 3Z"/>',
};
---

<svg
  class={cls}
  width={size}
  height={size}
  viewBox="0 0 24 24"
  fill="none"
  stroke="currentColor"
  stroke-width="1.6"
  stroke-linecap="round"
  stroke-linejoin="round"
  aria-hidden="true"
  set:html={paths[name]}
/>
