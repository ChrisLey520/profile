---
import { copy, type Lang } from '../data/site';
interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const c = copy[lang];
const year = 2026;
---

<footer class="footer">
  <div class="wrap footer-inner">
    <div class="footer-brand">
      <span class="brand-dot" aria-hidden="true"></span>
      <span>{c.name} · ChrisLey</span>
    </div>
    <p class="footer-meta">
      © {year} {c.name} · {c.footer.rights}
    </p>
    <p class="footer-built">{c.footer.built}</p>
    <a class="footer-lang" href={c.altHref}>{lang === 'en' ? '中文' : 'English'}</a>
  </div>
</footer>

<style>
  .footer {
    border-top: 1px solid var(--hairline);
    padding-block: 40px;
  }
  .footer-inner {
    display: flex;
    align-items: center;
    gap: 14px 26px;
    flex-wrap: wrap;
    font-size: 0.86rem;
    color: var(--muted);
  }
  .footer-brand {
    display: inline-flex;
    align-items: center;
    gap: 9px;
    font-family: var(--font-display);
    color: var(--text);
  }
  .brand-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: radial-gradient(circle at 35% 35%, var(--glow), var(--amber));
    box-shadow: 0 0 10px 1px rgba(255, 180, 84, 0.6);
  }
  .footer-meta {
    margin: 0;
  }
  .footer-built {
    margin: 0;
    font-family: var(--font-mono);
    font-size: 0.74rem;
    letter-spacing: 0.04em;
  }
  .footer-lang {
    margin-left: auto;
    font-family: var(--font-mono);
    font-size: 0.78rem;
    color: var(--text-2);
    border: 1px solid var(--hairline);
    border-radius: var(--r-pill);
    padding: 5px 13px;
    transition: border-color 0.25s ease, color 0.25s ease;
  }
  .footer-lang:hover {
    border-color: var(--glow);
    color: var(--glow);
  }
</style>
